# Copie para ".env" (nunca commitar o .env de verdade) e preencha os valores reais.

# Código exigido na tela de cadastro — sem ele, ninguém consegue criar conta (cadastro é público,
# mas fechado). Gere algo aleatório, ex.: `openssl rand -hex 16`.
Auth__InviteCode=

# Anthropic (agente de IA)
Agente__ApiKey=

# Gmail (OAuth) — ClientId/ClientSecret do Google Cloud Console; RefreshToken obtido rodando
# `dotnet run --project src/Services -- --auth` localmente (abre o navegador uma vez).
Gmail__ClientId=
Gmail__ClientSecret=
Gmail__RefreshToken=

# Senha para abrir PDFs de fatura protegidos (deixe vazio se nenhuma fatura usar senha).
Pdf__Password=

# Varredura automática diária de faturas (WebApp) — ajuste se quiser desligar ou mudar o horário.
AutoSearchFaturas__Enabled=true
AutoSearchFaturas__HoraExecucao=03:00

# Autentica o envio de telemetria (OTLP) pro Aspire Dashboard — sem isso, o endpoint aceitaria
# dados de qualquer app não autenticado. Gere algo aleatório, ex.: `openssl rand -hex 32`.
ASPIRE_OTLP_APIKEY=

# WhatsApp / Evolution API
# URL pública da Evolution (a que o Caddy expõe). Ex.: https://evolution.seudominio.com
EVOLUTION_SERVER_URL=
# Chave mestra da API (header "apikey"). Gere algo aleatório, ex.: `openssl rand -hex 32`.
EVOLUTION_API_KEY=
# Senha do Postgres dedicado da Evolution. Gere algo aleatório, ex.: `openssl rand -hex 16`.
EVOLUTION_POSTGRES_PASSWORD=
# Destino dos alertas E origem dos boletos importados. Para importar boletos de um GRUPO, use o JID do
# grupo (ex.: 120363039104311645@g.us) — os alertas também vão pra lá. Contato individual: DDI+DDD.
EVOLUTION_RECIPIENT_NUMBER=
# Nome da instância do WhatsApp na Evolution (pareada via QR code). Opcional (default: financeiro).
EVOLUTION_INSTANCE=financeiro
# Dono das faturas importadas pelo webhook do grupo. Vazio = usa o único usuário cadastrado (app pessoal).
# Se houver mais de um usuário, defina o UserId (AspNetUsers.Id) dono.
EVOLUTION_OWNER_USER_ID=
