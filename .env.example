# Copie para ".env" (nunca commitar o .env de verdade) e preencha os valores reais.

# Código exigido na tela de cadastro — sem ele, ninguém consegue criar conta (cadastro é público,
# mas fechado). Gere algo aleatório, ex.: `openssl rand -hex 16`.
Auth__InviteCode=

# Anthropic (agente de IA)
Agente__ApiKey=

# Gmail (OAuth) — ClientId/ClientSecret do Google Cloud Console; RefreshToken obtido rodando
# `dotnet run --project src/Services -- --auth` localmente (abre o navegador uma vez).
Gmail__ClientId=
Gmail__ClientSecret=
Gmail__RefreshToken=

# Senha para abrir PDFs de fatura protegidos (deixe vazio se nenhuma fatura usar senha).
Pdf__Password=

# Varredura automática diária de faturas (WebApp) — ajuste se quiser desligar ou mudar o horário.
AutoSearchFaturas__Enabled=true
AutoSearchFaturas__HoraExecucao=03:00
