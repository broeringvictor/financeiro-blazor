<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Saldo</MudText>
            @if (_carregando)
            {
                <MudSkeleton Width="60%" Height="40px" />
            }
            else
            {
                <MudText Typo="Typo.h4" Color="@(_saldo >= 0 ? Color.Success : Color.Error)">
                    @_saldo.ToString("C", _culture)
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Receitas − despesas (transações)</MudText>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="8">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Previsão do mês (contas)</MudText>
            @if (_carregando)
            {
                <MudSkeleton Width="60%" Height="40px" />
            }
            else
            {
                <MudText Typo="Typo.h4">@_previsao.Total.ToString("C", _culture)</MudText>

                @if (_previsao.Itens.Count > 0)
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                        @foreach (var item in _previsao.Itens)
                        {
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(item.ValorPrevisto is null ? Color.Default : Color.Primary)"
                                     title="@item.Origem">
                                @item.Nome: @(item.ValorPrevisto?.ToString("C", _culture) ?? "sem previsão")
                            </MudChip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Nenhuma conta ativa cadastrada.</MudText>
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle2" Class="mb-2">Gastos por mês</MudText>
    @if (_carregando)
    {
        <MudSkeleton Width="100%" Height="280px" />
    }
    else if (_gastosPorMes.All(g => g.Total == 0))
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Sem despesas registradas nos últimos 12 meses.</MudText>
    }
    else
    {
        <MudChart ChartType="ChartType.Bar"
                  ChartSeries="@_series"
                  XAxisLabels="@_labels"
                  ChartOptions="@_chartOptions"
                  Width="100%" Height="280px" />
    }
</MudPaper>
