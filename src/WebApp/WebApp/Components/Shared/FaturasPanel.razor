@if (!string.IsNullOrEmpty(UserId))
{
    <InvoicesGrid @ref="_grid"
                  UserId="@UserId"
                  BillId="@BillId"
                  Tipo="@Tipo"
                  OnPay="PagarFatura"
                  OnCancel="CancelarFatura"
                  OnDelete="ExcluirFatura"
                  OnEdit="EditarFatura" />
}
