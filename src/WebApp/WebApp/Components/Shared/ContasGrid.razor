@using WebApp.Extensions
@using WebApp.Models
@using WebApp.Models.Enums

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h6">@(_isIncome ? "Entradas" : "Saídas")</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="NovaConta">
        @(_isIncome ? "Nova entrada" : "Nova saída")
    </MudButton>
</MudStack>

<MudDataGrid T="Bill" Items="_bills" Hover="true" Dense="true" Striped="true"
             RowClick="@(e => VerFaturas(e.Item))" RowStyle="cursor:pointer">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Nome" />
        <PropertyColumn Property="x => x.BillerName" Title="@(_isIncome ? "Fonte" : "Fornecedor")">
            <CellTemplate>
                @context.Item.BillerName
                @if (!_isIncome && !string.IsNullOrEmpty(context.Item.PixKey))
                {
                    <div class="d-flex align-center" @onclick:stopPropagation="true">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Pix: @context.Item.PixKey</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       title="Copiar Pix"
                                       OnClick="@(() => CopiarPix(context.Item.PixKey))" />
                    </div>
                }
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Category!.Name" Title="Categoria">
            <CellTemplate>
                @if (context.Item.Category is { } c)
                {
                    @(c.Parent is null ? c.Name : $"{c.Parent.Name} › {c.Name}")
                }
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Recorrência">
            <CellTemplate>
                @context.Item.Recurrence.Frequency.GetDisplayName() • dia @context.Item.Recurrence.DueDay
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Ativa">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Item.Active ? Color.Success : Color.Default)">
                    @(context.Item.Active ? "Sim" : "Não")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Busca auto" Hidden="_isIncome">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Item.AutoSearch ? Color.Info : Color.Default)">
                    @(context.Item.AutoSearch ? "Sim" : "Não")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Ações" CellStyle="white-space:nowrap">
            <CellTemplate>
                <div @onclick:stopPropagation="true">
                    @if (!_isIncome && context.Item.AutoSearch)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Search"
                                       Size="Size.Small"
                                       Color="Color.Info"
                                       title="Buscar fatura agora"
                                       OnClick="@(() => BuscarConta(context.Item))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   title="Editar"
                                   OnClick="@(() => EditarConta(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   title="Excluir"
                                   OnClick="@(() => ExcluirConta(context.Item))" />
                </div>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent>
        <MudText Class="pa-4">@(_isIncome ? "Nenhuma entrada cadastrada." : "Nenhuma saída cadastrada.")</MudText>
    </NoRecordsContent>
</MudDataGrid>
