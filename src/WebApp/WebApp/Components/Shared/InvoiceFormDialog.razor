@using WebApp.Extensions
@using WebApp.Models
@using WebApp.Models.Enums

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:360px">
            <MudNumericField @bind-Value="_amount" Label="Valor" Variant="Variant.Outlined"
                             Adornment="Adornment.Start" AdornmentText="R$" Min="0" />

            <MudDatePicker @bind-Date="_dueDate" Label="Vencimento" Variant="Variant.Outlined" />

            <MudDatePicker @bind-Date="_issueDate" Label="Emissão (opcional)" Variant="Variant.Outlined" Clearable="true" />

            <MudSelect T="EInvoiceStatus" @bind-Value="_status" Label="Situação" Variant="Variant.Outlined">
                @foreach (var status in _situacoesPermitidas)
                {
                    <MudSelectItem Value="status">@status.GetDisplayName()</MudSelectItem>
                }
            </MudSelect>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error">@_error</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>
