@using Microsoft.Extensions.DependencyInjection
@using WebApp.Extensions
@using WebApp.Models
@using WebApp.Models.Enums
@using WebApp.Models.ValueObjects
@using WebApp.Services

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:420px">
            <MudTextField @bind-Value="_name" Label="Nome" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_billerName" Label="@(_isIncome ? "Fonte/Pagador" : "Fornecedor")" Variant="Variant.Outlined" Required="true" />

            <CategoryPicker Categories="_categories"
                            Value="_categoryId"
                            ValueChanged="@(id => _categoryId = id)"
                            Label="Categoria" />

            <MudStack Row="true" Spacing="2">
                <MudSelect T="ERecurrenceFrequency" @bind-Value="_frequency" Label="Frequência" Variant="Variant.Outlined">
                    @foreach (var freq in Enum.GetValues<ERecurrenceFrequency>())
                    {
                        <MudSelectItem Value="freq">@freq.GetDisplayName()</MudSelectItem>
                    }
                </MudSelect>
                <MudNumericField @bind-Value="_interval" Label="A cada" Min="1" Variant="Variant.Outlined" />
                <MudNumericField @bind-Value="_dueDay" Label="Dia venc." Min="1" Max="31" Variant="Variant.Outlined" />
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudDatePicker @bind-Date="_startDate" Label="Início" Variant="Variant.Outlined" />
                <MudSelect T="EndMode" @bind-Value="_endMode" Label="Fim" Variant="Variant.Outlined">
                    <MudSelectItem Value="EndMode.Nenhum">Sem fim</MudSelectItem>
                    <MudSelectItem Value="EndMode.Data">Por data</MudSelectItem>
                    <MudSelectItem Value="EndMode.Meses">Por nº de meses</MudSelectItem>
                </MudSelect>
            </MudStack>

            @if (_endMode == EndMode.Data)
            {
                <MudDatePicker @bind-Date="_endDate" Label="Data fim" Variant="Variant.Outlined" Clearable="true" />
            }
            else if (_endMode == EndMode.Meses)
            {
                <MudNumericField @bind-Value="_months" Label="Quantidade de meses" Min="1" Max="600"
                                 Variant="Variant.Outlined" HelperText="Ex.: 11 gera 11 faturas" />
            }

            <MudNumericField @bind-Value="_fixedAmount" Label="Valor fixo (opcional)" Variant="Variant.Outlined"
                             Adornment="Adornment.Start" AdornmentText="R$" />

            @if (!_isIncome)
            {
                <MudTextField @bind-Value="_searchQuery"
                              Label="Consulta de busca (contexto p/ o agente)"
                              HelperText="Ex.: Celesc fatura OR boleto newer_than:120d"
                              Variant="Variant.Outlined"
                              Lines="2" />

                <MudTextField @bind-Value="_pixKey"
                              Label="Chave Pix do fornecedor (opcional)"
                              HelperText="Útil pra contas pagas manualmente, sem boleto por e-mail"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                              OnAdornmentClick="CopiarPix" />

                <MudSwitch @bind-Value="_autoSearch" Label="Busca automática" Color="Color.Primary" />
            }

            @if (Bill is not null)
            {
                <MudSwitch @bind-Value="_active" Label="Ativa" Color="Color.Primary" />
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error">@_error</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IServiceScopeFactory ScopeFactory

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Conta a editar; <c>null</c> abre em modo criação.</summary>
    [Parameter] public Bill? Bill { get; set; }

    /// <summary>Dono da conta (modo criação).</summary>
    [Parameter] public string UserId { get; set; } = string.Empty;

    /// <summary>Tipo do lançamento sendo criado/editado (entrada ou saída). Define as categorias e os campos exibidos.</summary>
    [Parameter] public ETransactionTypes Tipo { get; set; } = ETransactionTypes.Expense;

    private bool _isIncome => Tipo == ETransactionTypes.Income;

    private IReadOnlyList<Category> _categories = [];

    private string _name = string.Empty;
    private string _billerName = string.Empty;
    private Guid? _categoryId;
    private ERecurrenceFrequency _frequency = ERecurrenceFrequency.Monthly;
    private int _interval = 1;
    private int _dueDay = 10;
    private DateTime? _startDate = DateTime.Today;
    private DateTime? _endDate;
    private EndMode _endMode = EndMode.Nenhum;
    private int _months = 12;
    private decimal? _fixedAmount;

    /// <summary>Como o fim da recorrência é definido no formulário.</summary>
    private enum EndMode
    {
        Nenhum,
        Data,
        Meses,
    }
    private string? _searchQuery;
    private string? _pixKey;
    private bool _autoSearch;
    private bool _active = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var categorias = scope.ServiceProvider.GetRequiredService<CategoryService>();
        _categories = await categorias.GetTreeAsync(UserId, Tipo);

        if (Bill is null)
        {
            _categoryId = _categories.FirstOrDefault()?.Id;
            return;
        }

        _name = Bill.Name;
        _billerName = Bill.BillerName;
        _categoryId = Bill.CategoryId;
        _frequency = Bill.Recurrence.Frequency;
        _interval = Bill.Recurrence.Interval;
        _dueDay = Bill.Recurrence.DueDay;
        _startDate = Bill.Recurrence.StartDate.ToDateTime(TimeOnly.MinValue);
        _endDate = Bill.Recurrence.EndDate?.ToDateTime(TimeOnly.MinValue);
        // Um EndDate salvo é sempre uma data concreta; edição abre em "Por data" (não dá pra inferir "nº de meses").
        _endMode = Bill.Recurrence.EndDate is null ? EndMode.Nenhum : EndMode.Data;
        _fixedAmount = Bill.FixedAmount;
        _searchQuery = Bill.SearchQuery;
        _pixKey = Bill.PixKey;
        _autoSearch = Bill.AutoSearch;
        _active = Bill.Active;
    }

    private void Submit()
    {
        _error = null;

        if (_categoryId is not { } categoryId || ResolverCategoria(categoryId) is not { } category)
        {
            _error = "Selecione uma categoria.";
            return;
        }

        try
        {
            var startDate = DateOnly.FromDateTime(_startDate ?? DateTime.Today);

            DateOnly? endDate;
            if (_endMode == EndMode.Data)
            {
                endDate = _endDate is { } end ? DateOnly.FromDateTime(end) : null;
            }
            else if (_endMode == EndMode.Meses)
            {
                if (_months < 1)
                {
                    _error = "Informe uma quantidade de meses maior que zero.";
                    return;
                }

                // N meses/parcelas → data da N-ésima ocorrência (inclusive): a geração cria exatamente N faturas.
                endDate = new RecurrenceRule(_frequency, _interval, _dueDay, startDate).OccurrenceDate(_months);
            }
            else
            {
                endDate = null;
            }

            var recurrence = new RecurrenceRule(_frequency, _interval, _dueDay, startDate, endDate);

            if (Bill is null)
            {
                var nova = new Bill(UserId, _name, _billerName, category, recurrence,
                    _fixedAmount, _autoSearch, _searchQuery, _pixKey);
                MudDialog.Close(DialogResult.Ok(nova));
            }
            else
            {
                Bill.Edit(_name, _billerName, category, recurrence, _fixedAmount,
                    _active, _autoSearch, _searchQuery, _pixKey);
                MudDialog.Close(DialogResult.Ok(Bill));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private Category? ResolverCategoria(Guid id) =>
        _categories.Select(c => c.Id == id ? c : c.Children.FirstOrDefault(f => f.Id == id))
            .FirstOrDefault(c => c is not null);

    private void Cancel() => MudDialog.Cancel();

    private async Task CopiarPix()
    {
        if (string.IsNullOrWhiteSpace(_pixKey))
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _pixKey);
            Snackbar.Add("Pix copiado.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Não foi possível copiar o Pix.", Severity.Error);
        }
    }
}
